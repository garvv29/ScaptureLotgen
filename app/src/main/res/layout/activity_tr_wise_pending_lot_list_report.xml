<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.TrWisePendingLotListReportActivity">

    <include android:id="@+id/include"
        layout="@layout/toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        android:layout_below="@id/include"
        android:orientation="vertical">

        <!-- Title & Subtitle -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bags Activation"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_add_button"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSrno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:layout_marginStart="2dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="SrNo"/>

            <TextView
                android:id="@+id/tvBarcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:layout_marginStart="2dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="Lot"/>

            <TextView
                android:id="@+id/tvCrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:layout_marginStart="2dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="Crop"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:layout_marginStart="2dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="SLOC"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:layout_marginStart="2dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="Bags"/>

        </LinearLayout>

        <!-- RecyclerView for Barcode List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBarcodes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="14dp"
            tools:listitem="@layout/pendinglotlist_report"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

    </LinearLayout>

</RelativeLayout>