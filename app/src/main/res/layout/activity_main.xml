<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <include android:id="@+id/include"
        layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F9FF"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome Text -->
            <TextView
                android:id="@+id/tv_userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back, User"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recieve, Activate and Dispatch your production seed"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- Top Two Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Activate Lot Card -->
                <LinearLayout
                    android:id="@+id/btnRecieve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_blue"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/ivRecieve"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_qr_code"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recieve Lot"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:id="@+id/tv_pendingRecieve"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Lots Pending"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Loading Card -->
                <LinearLayout
                    android:id="@+id/btnBagActivation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_yellow"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/ivBagActivation"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_qr_code"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activate Lot"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:id="@+id/tv_pendingActivations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Lots Pending"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Top Two Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Loading Card -->
                <LinearLayout
                    android:id="@+id/btnLoading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_yellow"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/ivLoading"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_truck"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:id="@+id/tv_pendingLoading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Lots Pending"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Report Lot Card -->
                <LinearLayout
                    android:id="@+id/btnReport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_blue"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/report"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Report"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Top Two Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Loading Card -->
                <LinearLayout
                    android:id="@+id/btnGsSampling"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_blue"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_qr_code"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guard Sample"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Report Lot Card -->
                <LinearLayout
                    android:id="@+id/btnGsSlocshifting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_yellow"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_qr_code"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GS SLOC Shifting"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Total Lots Activated Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/white_card"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <!-- Left Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvMetricTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Lots Activated"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Value -->
                    <TextView
                        android:id="@+id/tvTotActivated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#000000"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <!-- Percentage Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginTop="4dp">

                        <!-- Up arrow icon -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_up"
                            android:layout_marginEnd="4dp"
                            app:tint="#2ECC71" />

                        <!-- Percentage text -->
                        <TextView
                            android:id="@+id/tvMetricChange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40%"
                            android:textColor="#2ECC71"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp"/>

                        <!-- Description -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="vs last month"
                            android:textColor="#666666"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Graph Section (Right) -->
                <ImageView
                    android:id="@+id/imgGraph"
                    android:layout_width="80dp"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom"
                    android:src="@drawable/chart_blue"
                    android:scaleType="fitEnd" />
            </LinearLayout>

            <!-- Total Loading Done Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/white_card"
                android:padding="16dp"
                android:elevation="2dp">

                <!-- Left Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Lots Dispatched"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Value -->
                    <TextView
                        android:id="@+id/tvTotDisp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#000000"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <!-- Percentage Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginTop="4dp">

                        <!-- Up arrow icon -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_down"
                            android:layout_marginEnd="4dp"
                            app:tint="#E74C3C" />

                        <!-- Percentage text -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10%"
                            android:textColor="#E74C3C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp"/>

                        <!-- Description -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="vs last month"
                            android:textColor="#666666"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Graph Section (Right) -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom"
                    android:src="@drawable/chart_red"
                    android:scaleType="fitEnd" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>