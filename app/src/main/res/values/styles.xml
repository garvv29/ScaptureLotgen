<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApp.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/light_blue</item>
        <!--<item name="android:windowLightStatusBar">false</item>-->
    </style>
    <style name="headline">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#49454F</item>
    </style>
    <style name="ticket_stat">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#49454F</item>
    </style>

    <style name="tickets_in_">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#49454F</item>
    </style>
    <style name="ticket_for">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">#837D8C</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    <style name="label_text">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textColor">#1D192B</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    <style name="label_text2">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textColor">#49454F</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="CustomDatePickerStyle" parent="@android:style/Widget.Material.DatePicker">
        <item name="android:headerBackground">@color/light_blue</item>
        <item name="android:calendarTextColor">@color/dark_blue</item>
    </style>
</resources>